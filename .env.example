# ============================================================
# RAG Studio — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://raguser:ragpass@localhost:5432/ragstudio

# ------------------------------------------------------------
# Cache / Message Broker
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------
# Celery (optional — defaults reuse REDIS_URL for broker + result backend)
# ------------------------------------------------------------
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
# CELERY_TASK_DEFAULT_QUEUE=default
# pytest / local synchronous execution — set True only for tests/smoke scripts
# CELERY_TASK_ALWAYS_EAGER=false

# ------------------------------------------------------------
# Vector Database
# ------------------------------------------------------------
QDRANT_URL=http://localhost:6333

# ------------------------------------------------------------
# LLM API Keys
# ------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
COHERE_API_KEY=...
GOOGLE_API_KEY=...

# RAGAS evaluation (optional overrides — defaults in apps/api/app/config.py)
# EVALUATION_LLM_MODEL=gpt-4o-mini
# EVALUATION_EMBEDDING_MODEL=text-embedding-3-small
# Optional: Mistral chat (OpenAI-compatible client)
MISTRAL_API_KEY=
# Optional: Llama / Together / vLLM — OpenAI-compatible chat completions
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=

# ------------------------------------------------------------
# Experiment Tracking (P9-1 — Autopilot runs)
# ------------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000
# Set to false in CI or when MLflow is not reachable (builds still succeed).
MLFLOW_ENABLED=true
MLFLOW_EXPERIMENT_NAME=rag-studio-autopilot

# ------------------------------------------------------------
# Object Storage (MinIO / S3-compatible)
# ------------------------------------------------------------
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rag-studio-documents

# ------------------------------------------------------------
# Frontend → Backend URL
# ------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# ------------------------------------------------------------
# PostgreSQL (used directly by docker-compose.yml)
# ------------------------------------------------------------
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpass
POSTGRES_DB=ragstudio

# ------------------------------------------------------------
# Redis (production password)
# ------------------------------------------------------------
REDIS_PASSWORD=changeme

# ------------------------------------------------------------
# Docker / CI
# ------------------------------------------------------------
IMAGE_TAG=latest
GITHUB_REPOSITORY=yourusername/rag-studio

# ------------------------------------------------------------
# App Settings
# ------------------------------------------------------------
APP_ENV=development
SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO
# Pre-auth user id for /api/projects scoping (replaced by JWT in P12)
# DEFAULT_USER_ID=00000000-0000-4000-8000-000000000001
AUTH_REQUIRED=false
AUTH_ACCESS_TOKEN_TTL_MINUTES=60
# CSV list format: email:password:role:user_uuid
AUTH_BOOTSTRAP_USERS=admin@ragstudio.local:admin123:admin:00000000-0000-4000-8000-000000000001,user@ragstudio.local:user123:user:00000000-0000-4000-8000-000000000002
AUTH_RATE_LIMIT_PER_MINUTE=120
# Optional static token for web server-side requests
# NEXT_PUBLIC_API_BEARER_TOKEN=

# Optional — P2-9 cost estimator (`apps/api/catalogs/pricing.json` is the default)
# PRICING_CATALOG_PATH=

# Optional — P4-5 templates catalog (repo `data/templates.json` is the default)
# TEMPLATES_CATALOG_PATH=

# Optional — P4.5-7 guardrail operator policies (JSON — see apps/api/config/guardrails/examples/)
# GUARDRAILS_TOXICITY_POLICY_PATH=
# GUARDRAILS_CONTENT_FILTER_POLICY_PATH=
# GUARDRAILS_BIAS_PATTERNS_POLICY_PATH=

# ------------------------------------------------------------
# Observability overlay (Phase 11 — Prometheus + Grafana, optional Compose file)
# ------------------------------------------------------------
# Used by docker/docker-compose.observability.yml when merged with the base stack:
# PROMETHEUS_PORT=9090
# GF_SERVER_HTTP_PORT=3100
# GF_SECURITY_ADMIN_USER=admin
# GF_SECURITY_ADMIN_PASSWORD=admin
