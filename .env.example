# ============================================================
# RAG Studio — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://raguser:ragpass@localhost:5432/ragstudio

# ------------------------------------------------------------
# Cache / Message Broker
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------
# Vector Database
# ------------------------------------------------------------
QDRANT_URL=http://localhost:6333

# ------------------------------------------------------------
# LLM API Keys
# ------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
COHERE_API_KEY=...
GOOGLE_API_KEY=...
# Optional: Mistral chat (OpenAI-compatible client)
MISTRAL_API_KEY=
# Optional: Llama / Together / vLLM — OpenAI-compatible chat completions
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=

# ------------------------------------------------------------
# Experiment Tracking
# ------------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000

# ------------------------------------------------------------
# Object Storage (MinIO / S3-compatible)
# ------------------------------------------------------------
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rag-studio-documents

# ------------------------------------------------------------
# Frontend → Backend URL
# ------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# ------------------------------------------------------------
# PostgreSQL (used directly by docker-compose.yml)
# ------------------------------------------------------------
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpass
POSTGRES_DB=ragstudio

# ------------------------------------------------------------
# Redis (production password)
# ------------------------------------------------------------
REDIS_PASSWORD=changeme

# ------------------------------------------------------------
# Docker / CI
# ------------------------------------------------------------
IMAGE_TAG=latest
GITHUB_REPOSITORY=yourusername/rag-studio

# ------------------------------------------------------------
# App Settings
# ------------------------------------------------------------
APP_ENV=development
SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO
