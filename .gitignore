# Product tour screen-capture temp (see record:product-tour)
apps/web/.cache/
apps/web/public/videos/product-tour-main.silent.tmp.mp4
apps/web/public/videos/*.muxing.tmp.mp4

# Vitest snapshot files are committed (they are the expected output)
# Vitest coverage output is ignored
apps/web/coverage/

# ============================================================
# Build artifacts
# ============================================================
*.tgz
*.tar.gz

# ============================================================
# Next.js / Frontend specific (P0-5)
# ============================================================
# Generated by Next.js standalone build
apps/web/.next/
apps/web/out/
apps/web/.next/standalone/
# Storybook
storybook-static/
# Bundle analysis
.next/analyze/

# ------------------------------------------------------------
# Celery (optional local beat / schedule files — not committed)
# ------------------------------------------------------------
apps/api/celerybeat-schedule
apps/api/celerybeat-schedule.*
celerybeat-schedule

# ------------------------------------------------------------
# Guardrails — operator-specific JSON policies (P4.5-7)
# ------------------------------------------------------------
apps/api/config/guardrails/local/

# ------------------------------------------------------------
# Next.js — local trace files (profiling / debugging)
# ------------------------------------------------------------
**/.next/trace

# ------------------------------------------------------------
# MLflow — default local file store when not using Docker volume (P9-1)
# ------------------------------------------------------------
mlruns/

# ------------------------------------------------------------
# Observability — optional local dumps (Phase 11; Compose uses named volumes)
# ------------------------------------------------------------
/grafana-export-*.json
/prometheus-debug/

# ------------------------------------------------------------
# Kubernetes production local overlays/secrets (Phase 12)
# ------------------------------------------------------------
k8s/production/secret.yaml
k8s/production/*.local.yaml

docs/
prompt_history/
TASKS.md
