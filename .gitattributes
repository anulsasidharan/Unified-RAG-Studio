# Normalize line endings to LF in the repo; check out as LF on all platforms.
* text=auto eol=lf

# Force LF for all source files
*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
*.txt   text eol=lf
*.sh    text eol=lf
*.env*  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
Dockerfile* text eol=lf

# Binary files — never diff/merge
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.pdf  binary
*.zip  binary
