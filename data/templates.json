            "systemPrompt": "You are a multilingual support assistant. Answer in the same language as the user's question. Base your answer only on the provided context. If the answer is not available, say so in the user's language.",
            "outputFormat": "text"
          },
          "routing": {
            "enabled": false
          },
          "memory": {
            "type": "conversation-buffer",
            "windowSize": 8,
            "sessionPersistence": true
          },
          "evaluation": {
            "enabled": true,
            "metrics": ["faithfulness", "answer_relevance"],
            "testSetSize": 50
          }
        },
        "metadata": {
          "version": "1.0.0",
          "source": "template",
          "createdAt": "2025-01-01T00:00:00Z"
        }
      }
    },
    {
      "id": "legal-research",
      "name": "Legal Research",
      "description": "High-precision RAG pipeline for legal document analysis. Uses semantic chunking, MMR retrieval, and Claude Opus for nuanced legal reasoning with citations.",
      "useCase": "Contract Analysis, Legal Research, Compliance QA, Case Law Retrieval",
      "complexity": "advanced",
      "estimatedMonthlyCost": "$100-500",
      "tags": ["legal", "high-precision", "citations", "anthropic", "semantic-chunking"],
      "providerLogos": ["anthropic", "openai", "cohere"],
      "config": {
        "id": "template-legal-research",
        "name": "Legal Research",
        "description": "High-precision legal document analysis with semantic chunking, MMR, reranking, and Claude Opus",
        "cloudProvider": "multi-cloud",
        "stages": {
          "dataIngestion": {
            "sourceType": "file-upload",
            "fileTypes": ["pdf", "docx", "txt"],
            "preprocessing": {
              "stripHtml": true,
              "normalizeWhitespace": true,
              "extractMetadata": true
            },
            "metadata": {
              "includeSource": true,
              "includePageNumber": true,
              "includeDocumentTitle": true
            }
          },
          "chunking": {
            "strategy": "semantic",
            "chunkSize": 1024,
            "chunkOverlap": 100,
            "breakpointThreshold": 0.95
          },
          "embedding": {
            "model": "text-embedding-3-large",
            "provider": "openai",
            "dimensions": 3072,
            "batchSize": 50
          },
          "vectorStore": {
            "provider": "qdrant",
            "indexName": "legal-index",
            "configuration": {
              "metric": "cosine"
            }
          },
          "retrieval": {
            "strategy": "mmr",
            "topK": 10,
            "scoreThreshold": 0.6,
            "fetchK": 30,
            "lambdaMult": 0.7
          },
          "reranking": {
            "enabled": true,
            "model": "cohere-rerank-v3",
            "topN": 6
          },
          "generation": {
            "model": "claude-opus-4-7",
            "provider": "anthropic",
            "temperature": 0.0,
            "maxTokens": 4096,
            "systemPrompt": "You are a legal research assistant. Provide precise, well-reasoned answers based strictly on the provided legal documents. Always cite specific sections, clauses, or page numbers. Distinguish clearly between what is stated in the documents and any legal interpretation. Never speculate beyond the provided text.",
            "outputFormat": "markdown"
          },
          "routing": {
            "enabled": false
          },
          "memory": {
            "type": "conversation-buffer",
            "windowSize": 10,
            "sessionPersistence": true
          },
          "evaluation": {
            "enabled": true,
            "metrics": ["faithfulness", "answer_relevance", "context_precision", "context_recall"],
            "testSetSize": 100
          }
        },
        "metadata": {
          "version": "1.0.0",
          "source": "template",
          "createdAt": "2025-01-01T00:00:00Z"
        }
      }
    },
    {
      "id": "customer-support",
      "name": "Customer Support",
      "description": "Conversational RAG pipeline for customer support with memory. Balances accuracy and cost with conversation history tracking.",
      "useCase": "E-commerce Support, SaaS Help Desk, Product Support, Ticketing Systems",
      "complexity": "beginner",
      "estimatedMonthlyCost": "$10-40",
      "tags": ["customer-support", "conversational", "memory", "cost-balanced"],
      "providerLogos": ["openai"],
      "config": {
        "id": "template-customer-support",
        "name": "Customer Support",
        "description": "Conversational customer support RAG with session memory and fast inference",
        "cloudProvider": "multi-cloud",
        "stages": {
          "dataIngestion": {
            "sourceType": "file-upload",
            "fileTypes": ["pdf", "docx", "txt", "html"],
            "preprocessing": {
              "stripHtml": true,
              "normalizeWhitespace": true,
              "extractMetadata": true
            },
            "metadata": {
              "includeSource": true,
              "includePageNumber": false
            }
          },
          "chunking": {
            "strategy": "paragraph-based",
            "chunkSize": 256,
            "chunkOverlap": 30,
            "separator": "\n\n"
          },
          "embedding": {
            "model": "text-embedding-3-small",
            "provider": "openai",
            "dimensions": 1536,
            "batchSize": 100
          },
          "vectorStore": {
            "provider": "qdrant",
            "indexName": "support-index",
            "configuration": {
              "metric": "cosine"
            }
          },
          "retrieval": {
            "strategy": "similarity",
            "topK": 4,
            "scoreThreshold": 0.65
          },
          "reranking": {
            "enabled": true,
            "model": "flashrank",
            "topN": 3
          },
          "generation": {
            "model": "gpt-4o-mini",
            "provider": "openai",
            "temperature": 0.4,
            "maxTokens": 768,
            "systemPrompt": "You are a friendly and helpful customer support agent. Answer the customer's question based on the provided knowledge base. Be empathetic, clear, and actionable. If you cannot find the answer in the context, politely acknowledge this and suggest contacting human support.",
            "outputFormat": "text"
          },
          "routing": {
            "enabled": true,
            "defaultModel": "gpt-4o-mini",
            "rules": [
              {
                "condition": "query-length",
                "threshold": 120,
                "targetModel": "gpt-4o-mini"
              },
              {
                "condition": "semantic-complexity",
                "threshold": 0.65,
                "targetModel": "gpt-4o"
              }
            ]
          },
          "memory": {
            "type": "conversation-buffer",
            "windowSize": 6,
            "sessionPersistence": true
          },
          "evaluation": {
            "enabled": true,
            "metrics": ["faithfulness", "answer_relevance"],
            "testSetSize": 50
          }
        },
        "metadata": {
          "version": "1.0.0",
          "source": "template",
          "createdAt": "2025-01-01T00:00:00Z"
        }
      }
    }
  ]
}
