  "costCalculatorFormulas": {
    "description": "Formulas used by the cost calculator to estimate per-query and per-month costs",
    "embeddingCostPerQuery": {
      "formula": "(avgChunksRetrievedPerQuery * avgChunkSizeTokens / 1000000) * embeddingCostPer1MTokens",
      "description": "Cost to embed the query (query tokens * embedding price)"
    },
    "generationCostPerQuery": {
      "formula": "(contextTokens * inputCostPer1MTokens / 1000000) + (avgOutputTokens * outputCostPer1MTokens / 1000000)",
      "contextTokens": "avgChunksRetrievedPerQuery * avgChunkSizeTokens + avgInputTokensPerQuery",
      "description": "Cost for LLM call: (retrieved context + user query) * input price + output * output price"
    },
    "rerankingCostPerQuery": {
      "formula": "(costPer1KQueries / 1000) * (1 if enabled else 0)",
      "description": "Cost per query for reranking (if enabled)"
    },
    "storageCostPerMonth": {
      "formula": "totalVectorStorageGB * costPerGBPerMonth",
      "totalVectorStorageGB": "(totalDocumentTokens / avgChunkSizeTokens * embeddingDimensions * 4 bytes) / 1073741824",
      "description": "Monthly cost to store all document vectors. 4 bytes per float32 dimension."
    },
    "totalCostPerQuery": {
      "formula": "embeddingCostPerQuery + generationCostPerQuery + rerankingCostPerQuery",
      "description": "Total variable cost per user query"
    },
    "totalCostPerMonth": {
      "formula": "totalCostPerQuery * queriesPerMonth + storageCostPerMonth",
      "description": "Total monthly cost = per-query costs at scale + fixed storage cost"
    }
  },
