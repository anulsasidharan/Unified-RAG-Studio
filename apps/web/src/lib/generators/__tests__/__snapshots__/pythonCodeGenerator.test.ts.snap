// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`generatePythonCode > matches snapshot for minimal config 1`] = `
""""
RAG Pipeline — Test RAG Pipeline
Generated by RAG Studio
Cloud Provider: aws
Model: gpt-4o-mini
Vector Store: qdrant
Chunking: recursive-character (512 tokens)
"""

import os
from typing import List

# LangChain core
from langchain_core.prompts import ChatPromptTemplate
from langchain_core.output_parsers import StrOutputParser
from langchain_core.runnables import RunnablePassthrough, RunnableParallel
from langchain_core.documents import Document

# Text splitting
from langchain_text_splitters import RecursiveCharacterTextSplitter

# Embeddings
from langchain_openai import OpenAIEmbeddings

# LLM
from langchain_openai import ChatOpenAI

# Vector store
from langchain_qdrant import QdrantVectorStore
from qdrant_client import QdrantClient


# ─── Configuration ──────────────────────────────────────────────────────────

CLOUD_PROVIDER = "aws"
INDEX_NAME = "rag-documents"
EMBEDDING_MODEL = "text-embedding-3-small"
EMBEDDING_DIMENSIONS = 1536
LLM_MODEL = "gpt-4o-mini"
TEMPERATURE = 0.1
MAX_TOKENS = 1024
CHUNK_SIZE = 512
CHUNK_OVERLAP = 50
TOP_K = 5

# ─── Embeddings ─────────────────────────────────────────────────────────────

embeddings = OpenAIEmbeddings(
    model="text-embedding-3-small"
)

# ─── LLM ────────────────────────────────────────────────────────────────────

llm = ChatOpenAI(
    model="gpt-4o-mini",
    temperature=0.1,
    max_tokens=1024
)

# ─── Text splitter ──────────────────────────────────────────────────────────

text_splitter = RecursiveCharacterTextSplitter(
    chunk_size=512,
    chunk_overlap=50,
    separators=["\\n\\n","\\n"," "],
)


# ─── Vector Store (Qdrant) ──────────────────────────────────────────────────

qdrant_client = QdrantClient(
    url=os.environ["QDRANT_URL"],
    api_key=os.environ.get("QDRANT_API_KEY"),
)

vector_store = QdrantVectorStore(
    client=qdrant_client,
    collection_name="rag-documents",
    embedding=embeddings,
    distance="COSINE",
)


# ─── Retriever ──────────────────────────────────────────────────────────────

base_retriever = vector_store.as_retriever(
    search_type="similarity",
    search_kwargs={"k": 5},
)
retriever = base_retriever


# ─── Prompt ─────────────────────────────────────────────────────────────────

prompt = ChatPromptTemplate.from_messages([
    ("system", """You are a helpful assistant. Use the provided context to answer the question accurately.

Context:
{context}
Format your answer using Markdown.
"""),
    ("human", "{question}"),
])

# ─── Chain (LCEL) ───────────────────────────────────────────────────────────

def format_docs(docs: List[Document]) -> str:
    return "\\n\\n".join(doc.page_content for doc in docs)

rag_chain = (
    RunnableParallel(
        context=retriever | format_docs,
        question=RunnablePassthrough(),
    )
    | prompt
    | llm
    | StrOutputParser()
)


# ─── Indexing helper ────────────────────────────────────────────────────────

def index_documents(file_paths: list[str]) -> int:
    """Load, chunk, embed, and store documents. Returns chunk count."""
    from langchain_community.document_loaders import UnstructuredFileLoader
    
    all_docs: List[Document] = []
    for path in file_paths:
        loader = UnstructuredFileLoader(path)
        all_docs.extend(loader.load())
    
    chunks = text_splitter.split_documents(all_docs)
    vector_store.add_documents(chunks)
    return len(chunks)


# ─── Inference ──────────────────────────────────────────────────────────────

def query(question: str, session_id: str = "default") -> str:
    """Run a RAG query and return the generated answer."""
    return rag_chain.invoke(question)


if __name__ == "__main__":
    # Quick smoke test
    answer = query("What is this document about?")
    print(answer)"
`;
